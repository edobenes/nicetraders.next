  },
  "homepage": "https://github.com/edobenes/nicetraders.next#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "puppeteer-core": "^24.42.0"
  }
}
