{
  "name": "nicetraders-next",
  "version": "1.0.0",
  "description": "Static NICE Traders frontend with a local development authentication API.",
  "type": "module",
  "main": "backend/server.mjs",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "dev": "node backend/server.mjs",
    "start": "node backend/server.mjs",
    "test": "node --test test/*.test.mjs",
    "test:e2e": "node test/e2e-auth.mjs",
    "mcp": "node mcp/server.mjs",
    "mcp:http": "node mcp/server.mjs --http",
    "test:mcp": "node --test test/mcp.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edobenes/nicetraders.next.git"
  },
